<Window x:Class="SchoolJournalApp.AddAttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметка посещаемости" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата:" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDate" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="1" Grid.Column="1" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="Присутствовал"/>
            <ComboBoxItem Content="Прогул неуважительный"/>
            <ComboBoxItem Content="Прогул уважительный"/>
            <ComboBoxItem Content="Больничный"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Примечание:" VerticalAlignment="Top"/>
        <TextBox x:Name="txtNote" Grid.Row="2" Grid.Column="1" Margin="5" Height="80" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>