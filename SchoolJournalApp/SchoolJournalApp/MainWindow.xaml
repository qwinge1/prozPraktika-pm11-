<Window x:Class="SchoolJournalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Школьный журнал — Электронная система учёта успеваемости"
        Height="750" Width="1050" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Стили (без изменений) -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#34495E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A252F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F171E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="110"/>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="SaveButton">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,0,0" Margin="2,0,2,0">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
    </Window.Resources>

    <Border Background="#F0F2F5" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🏫" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Школьный журнал" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="   |   Система учёта успеваемости" FontSize="14" Foreground="#BDC3C7" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="ℹ️ О программе" Background="Transparent" BorderThickness="0" 
                            Foreground="White" Cursor="Hand" FontSize="13" 
                            Click="btnAbout_Click" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Вкладки -->
            <TabControl Grid.Row="1" Margin="15" Background="White" BorderThickness="0">
                <!-- ========== Вкладка Ученики ========== -->
                <TabItem Header="📋 Ученики">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Панель фильтрации учеников -->
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="10" Margin="0,0,0,15" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Класс:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="cmbFilterClass" Width="100" DisplayMemberPath="Класс" SelectedValuePath="ID_класса" 
                                          SelectionChanged="FilterStudents_Click" />
                                <TextBlock Text="ФИО:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                <TextBox x:Name="txtFilterName" Width="200" />
                                <Button Content="🔍 Применить" Width="100" Margin="10,0,0,0" Click="FilterStudents_Click"/>
                                <Button Content="❌ Сброс" Width="80" Margin="5,0,0,0" Click="ResetStudentsFilter_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки CRUD -->
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnAdd" Content="➕ Добавить" Style="{StaticResource ActionButton}" Width="110" Click="btnAdd_Click"/>
                                <Button x:Name="btnEdit" Content="✏️ Редактировать" Style="{StaticResource ActionButton}" Width="120" Click="btnEdit_Click"/>
                                <Button x:Name="btnDelete" Content="🗑️ Удалить" Style="{StaticResource DangerButton}" Width="100" Click="btnDelete_Click"/>
                                <Button x:Name="btnRefresh" Content="🔄 Обновить" Style="{StaticResource ActionButton}" Width="100" Click="btnRefresh_Click"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Список учеников -->
                        <ListView x:Name="lvStudents" Grid.Row="2">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ID_ученика}" Width="50"/>
                                    <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding ФИО}" Width="Auto"/>
                                    <GridViewColumn Header="Дата рождения" DisplayMemberBinding="{Binding Дата_рождения, StringFormat='yyyy-MM-dd'}" Width="100"/>
                                    <GridViewColumn Header="Класс" DisplayMemberBinding="{Binding Класс}" Width="80"/>
                                    <GridViewColumn Header="Логин" DisplayMemberBinding="{Binding Логин}" Width="120"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Форма редактирования -->
                        <Border x:Name="borderForm" Grid.Row="3" Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1"
                                CornerRadius="8" Margin="0,15,0,0" Padding="15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="📝 Редактирование данных ученика" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtFIO" Grid.Row="0" Grid.Column="1" Margin="5,5,0,5" Height="30"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата рождения (ГГГГ-ММ-ДД):" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtBirth" Grid.Row="1" Grid.Column="1" Margin="5,5,0,5" Height="30" ToolTip="Пример: 2010-05-15"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Класс:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbClass" Grid.Row="2" Grid.Column="1" Margin="5,5,0,5" Height="30" DisplayMemberPath="Класс" SelectedValuePath="ID_класса"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtLogin" Grid.Row="3" Grid.Column="1" Margin="5,5,0,5" Height="30"/>

                                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                        <Button x:Name="btnSave" Content="💾 Сохранить" Style="{StaticResource SaveButton}" Width="100" Click="btnSave_Click"/>
                                        <Button x:Name="btnCancel" Content="❌ Отмена" Style="{StaticResource DangerButton}" Width="100" Margin="10,0,0,0" Click="btnCancel_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ========== Вкладка Оценки и посещаемость ========== -->
                <TabItem Header="📋 Оценки и посещаемость">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Выбор ученика -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Ученик:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbStudentsForAttendance" Width="250" DisplayMemberPath="ФИО" SelectedValuePath="ID_ученика"
                                      SelectionChanged="cmbStudentsForAttendance_SelectionChanged"/>
                            <Button x:Name="btnRefreshAttendance" Content="🔄 Обновить" Width="100" Margin="20,0,0,0" Click="btnRefreshAttendance_Click"/>
                        </StackPanel>

                        <!-- Оценки ученика с фильтром по предмету -->
                        <GroupBox Grid.Row="1" Header="Оценки ученика" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Предмет:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="cmbGradeSubjectFilter" Width="150" DisplayMemberPath="Название" SelectedValuePath="ID_предмета"
                      SelectionChanged="FilterGrades_Click"/>
                                    <Button x:Name="btnAddGrade" Content="➕ Добавить оценку" Width="130" Margin="20,0,0,0" Click="btnAddGrade_Click"/>
                                    <Button x:Name="btnEditGrade" Content="✏️ Редактировать" Width="110" Margin="10,0,0,0" Click="btnEditGrade_Click"/>
                                    <Button x:Name="btnDeleteGrade" Content="🗑️ Удалить" Width="90" Margin="10,0,0,0" Click="btnDeleteGrade_Click" Style="{StaticResource DangerButton}"/>
                                </StackPanel>
                                <ListView x:Name="lvStudentGrades" Grid.Row="1" SelectionMode="Single">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ID_оценки}" Width="50"/>
                                            <GridViewColumn Header="Предмет" DisplayMemberBinding="{Binding Предмет}" Width="120"/>
                                            <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding Дата_получения, StringFormat='yyyy-MM-dd'}" Width="100"/>
                                            <GridViewColumn Header="Оценка" DisplayMemberBinding="{Binding Оценка}" Width="60"/>
                                            <GridViewColumn Header="Тип контроля" DisplayMemberBinding="{Binding Тип_контроля}" Width="100"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </GroupBox>

                        <!-- Посещаемость ученика с фильтром по статусу -->
                        <GroupBox Grid.Row="2" Header="Посещаемость" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="cmbAttendanceStatusFilter" Width="150" SelectedIndex="0" SelectionChanged="FilterAttendance_Click">
                                        <ComboBoxItem Content="Все"/>
                                        <ComboBoxItem Content="Присутствовал"/>
                                        <ComboBoxItem Content="Прогул неуважительный"/>
                                        <ComboBoxItem Content="Прогул уважительный"/>
                                        <ComboBoxItem Content="Больничный"/>
                                    </ComboBox>
                                    <Button x:Name="btnAddAttendance" Content="➕ Отметить посещаемость" Width="150" Margin="20,0,0,0" Click="btnAddAttendance_Click"/>
                                    <Button x:Name="btnEditAttendance" Content="✏️ Редактировать" Width="110" Margin="10,0,0,0" Click="btnEditAttendance_Click"/>
                                    <Button x:Name="btnDeleteAttendance" Content="🗑️ Удалить" Width="90" Margin="10,0,0,0" Click="btnDeleteAttendance_Click" Style="{StaticResource DangerButton}"/>
                                </StackPanel>
                                <ListView x:Name="lvAttendance" Grid.Row="1" SelectionMode="Single">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ID_посещаемости}" Width="50"/>
                                            <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding Дата, StringFormat='yyyy-MM-dd'}" Width="100"/>
                                            <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Статус}" Width="150"/>
                                            <GridViewColumn Header="Примечание" DisplayMemberBinding="{Binding Примечание}" Width="Auto"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- ========== Вкладка Отчёты ========== -->
                <TabItem Header="📊 Отчёты">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель отчётов 1-3 с фильтрами -->
                        <Border Grid.Row="0" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📈 Основные отчёты" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                                <!-- Отличники с фильтром по классу -->
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <Button x:Name="btnTopStudents" Content="🏆 Отличники" Style="{StaticResource ActionButton}" Width="140" Click="btnTopStudents_Click"/>
                                    <TextBlock Text="Класс:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <ComboBox x:Name="cmbTopClassFilter" Width="100" DisplayMemberPath="Класс" SelectedValuePath="ID_класса"/>
                                    <Button Content="Фильтр" Width="80" Margin="10,0,0,0" Click="btnTopStudents_Click"/>
                                </StackPanel>

                                <!-- Средний балл по классам с фильтром по году -->
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <Button x:Name="btnClassAvg" Content="📈 Средний балл по классам" Style="{StaticResource ActionButton}" Width="220" Click="btnClassAvg_Click"/>
                                    <TextBlock Text="Учебный год:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <ComboBox x:Name="cmbYearFilter" Width="100">
                                        <ComboBoxItem Content="2024-2025" IsSelected="True"/>
                                        <ComboBoxItem Content="2025-2026"/>
                                    </ComboBox>
                                    <Button Content="Фильтр" Width="80" Margin="10,0,0,0" Click="btnClassAvg_Click"/>
                                </StackPanel>

                                <!-- Успеваемость по предметам с фильтром по классу -->
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <Button x:Name="btnSubjectAvg" Content="📚 Успеваемость по предметам" Style="{StaticResource ActionButton}" Width="230" Click="btnSubjectAvg_Click"/>
                                    <TextBlock Text="Класс:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <ComboBox x:Name="cmbSubjectClassFilter" Width="100" DisplayMemberPath="Класс" SelectedValuePath="ID_класса"/>
                                    <Button Content="Фильтр" Width="80" Margin="10,0,0,0" Click="btnSubjectAvg_Click"/>
                                </StackPanel>

                                <Separator Margin="0,10,0,5"/>
                                <!-- Кнопки экспорта -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnExportCsv" Content="📄 Сохранить в CSV" Style="{StaticResource ActionButton}" Width="150" Click="btnExportCsv_Click" Background="#27AE60"/>
                                    <Button x:Name="btnExportXlsx" Content="📊 Сохранить в Excel" Style="{StaticResource ActionButton}" Width="160" Click="btnExportXlsx_Click" Background="#F39C12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Таблица для отображения отчётов -->
                        <ListView x:Name="lvReports" Grid.Row="1" Margin="0,0,0,15" Height="200">
                            <ListView.View>
                                <GridView x:Name="gvReports" />
                            </ListView.View>
                        </ListView>

                        <!-- Отчёт по посещаемости с фильтром по дате -->
                        <Border Grid.Row="2" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="📋 Отчёт по посещаемости" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Класс:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="cmbClassForAttendanceReport" Width="120" DisplayMemberPath="Класс" SelectedValuePath="ID_класса" 
          SelectionChanged="cmbClassForAttendanceReport_SelectionChanged"/>
                                    <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <DatePicker x:Name="dpAttendanceFrom" Width="100"/>
                                    <TextBlock Text="по:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                                    <DatePicker x:Name="dpAttendanceTo" Width="100"/>
                                    <Button x:Name="btnShowAttendanceReport" Content="📄 Показать" Width="100" Margin="10,0,0,0" 
                                            Style="{StaticResource ActionButton}" Click="btnShowAttendanceReport_Click"/>
                                    <Button x:Name="btnExportAttendanceReport" Content="📊 Excel" Width="100" Margin="10,0,0,0" 
                                            Style="{StaticResource ActionButton}" Background="#27AE60" Click="btnExportAttendanceReport_Click"/>
                                    <Button x:Name="btnExportAttendanceCsv" Content="📄 CSV" Width="80" Margin="10,0,0,0" 
                                            Style="{StaticResource ActionButton}" Background="#3498DB" Click="btnExportAttendanceCsv_Click"/>
                                </StackPanel>

                                <ListView x:Name="lvAttendanceReport" Grid.Row="2">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding ФИО}" Width="200"/>
                                            <GridViewColumn Header="Присутствий" DisplayMemberBinding="{Binding Присутствий}" Width="80"/>
                                            <GridViewColumn Header="Прогулы неуваж" DisplayMemberBinding="{Binding Прогулы_неуваж}" Width="120"/>
                                            <GridViewColumn Header="Прогулы уваж" DisplayMemberBinding="{Binding Прогулы_уваж}" Width="100"/>
                                            <GridViewColumn Header="Больничных" DisplayMemberBinding="{Binding Больничных}" Width="80"/>
                                            <GridViewColumn Header="Всего записей" DisplayMemberBinding="{Binding Всего_записей}" Width="100"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Статусбар -->
            <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
                <StatusBar Background="Transparent">
                    <StatusBarItem>
                        <TextBlock Foreground="White" FontSize="12" TextWrapping="Wrap">
                            ✅ База данных: подключена | 📅 Учебный год 2025-2026 | 🧑‍🎓 Учеников: <Run x:Name="txtStudentCount" Text="0"/>
                        </TextBlock>
                    </StatusBarItem>
                </StatusBar>
            </Border>
        </Grid>
    </Border>
</Window>