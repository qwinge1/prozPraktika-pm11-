<Window x:Class="SchoolJournalApp.AddGradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление оценки" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Предмет:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbSubject" Grid.Row="0" Grid.Column="1" Margin="5" DisplayMemberPath="Название" SelectedValuePath="ID_предмета"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Оценка:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbGrade" Grid.Row="1" Grid.Column="1" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тип контроля:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbControlType" Grid.Row="2" Grid.Column="1" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="текущая"/>
            <ComboBoxItem Content="контрольная"/>
            <ComboBoxItem Content="самостоятельная"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата:" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDate" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>